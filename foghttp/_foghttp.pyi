class RawUrl:
    def __init__(self, url: str) -> None: ...
    @property
    def value(self) -> str: ...
    @property
    def scheme(self) -> str: ...
    @property
    def host(self) -> str: ...
    @property
    def port(self) -> int: ...
    @property
    def path(self) -> str: ...
    @property
    def query(self) -> str: ...
    @property
    def fragment(self) -> str: ...
    @property
    def origin(self) -> str: ...
    def join(self, location: str) -> RawUrl: ...
    def is_same_origin(self, other: RawUrl) -> bool: ...

class RawUploadBody:
    def __init__(
        self,
        content_length: int | None,
        start_callback: object,
        replayable: bool,
        ready_callback: object | None,
    ) -> None: ...
    def send(self, chunk: bytes) -> bool: ...
    def send_nowait(self, chunk: bytes) -> bool: ...
    def is_closed(self) -> bool: ...
    def finish(self) -> None: ...
    def fail(self, message: str) -> None: ...
    def fail_nowait(self, message: str) -> bool: ...
    def close(self) -> None: ...

class RawClient:
    def __init__(
        self,
        max_active_requests: int,
        max_active_requests_per_origin: int | None,
        max_idle_connections_per_host: int,
        max_pending_requests: int,
        max_response_body_size: int | None,
        max_buffered_response_bytes: int | None,
        idle_timeout: float,
        keepalive: bool,
        connect_timeout: float,
        follow_redirects: bool,
        max_redirects: int,
        ca_certificates: Sequence[bytes],
        trust_webpki_roots: bool,
        runtime_workers: int | None,
        http_proxy_url: str | None,
        http_proxy_authorization: str | None,
        https_proxy_url: str | None,
        https_proxy_authorization: str | None,
    ) -> None: ...
    def request(
        self,
        method: str,
        url: str,
        headers: HeaderPairs,
        body: bytes | None,
        body_stream: RawUploadBody | None,
        body_replayable: bool,
        use_proxy_transport: bool,
        proxy_policy: str,
        pool_timeout: float,
        read_timeout: float,
        write_timeout: float,
        total_timeout: float,
    ) -> RawResponse: ...
    async def request_async(
        self,
        method: str,
        url: str,
        headers: HeaderPairs,
        body: bytes | None,
        body_stream: RawUploadBody | None,
        body_replayable: bool,
        use_proxy_transport: bool,
        proxy_policy: str,
        pool_timeout: float,
        read_timeout: float,
        write_timeout: float,
        total_timeout: float,
    ) -> RawResponse: ...
    def request_stream(
        self,
        method: str,
        url: str,
        headers: HeaderPairs,
        body: bytes | None,
        body_stream: RawUploadBody | None,
        body_replayable: bool,
        use_proxy_transport: bool,
        proxy_policy: str,
        pool_timeout: float,
        read_timeout: float,
        write_timeout: float,
        total_timeout: float,
    ) -> RawStreamResponse: ...
    async def request_stream_async(
        self,
        method: str,
        url: str,
        headers: HeaderPairs,
        body: bytes | None,
        body_stream: RawUploadBody | None,
        body_replayable: bool,
        use_proxy_transport: bool,
        proxy_policy: str,
        pool_timeout: float,
        read_timeout: float,
        write_timeout: float,
        total_timeout: float,
    ) -> RawStreamResponse: ...
    def stats(self) -> RawStats: ...
    def transport_state(self) -> RawTransportState: ...
    def pool_diagnostics(self) -> RawPoolDiagnostics: ...
    def close(self) -> None: ...
